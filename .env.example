DIRECTUS_URL=http://localhost:8055
DIRECTUS_EMAIL=admin@example.com
DIRECTUS_PASSWORD=change-me-please

# Optional. If present, scripts use this instead of logging in with email/password.
DIRECTUS_TOKEN=

POSTGRES_DB=directus
POSTGRES_USER=directus
POSTGRES_PASSWORD=directus-local-password
DIRECTUS_KEY=replace-with-a-long-random-key
DIRECTUS_SECRET=replace-with-a-long-random-secret

# OAuth gate in front of the admin UI.
# The callback/redirect URL registered at your provider should be:
# http://localhost:4173/oauth2/callback
#
# For GitHub OAuth Apps:
# OAUTH2_PROXY_PROVIDER=github
#
# For Google or another OpenID Connect provider:
# OAUTH2_PROXY_PROVIDER=oidc
# OAUTH2_PROXY_OIDC_ISSUER_URL=https://accounts.google.com
OAUTH2_PROXY_PROVIDER=github
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=

# Generate with:
# openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=
OAUTH2_PROXY_COOKIE_SECURE=false
OAUTH2_PROXY_COOKIE_SAMESITE=lax
OAUTH2_PROXY_EMAIL_DOMAINS=*
OAUTH2_PROXY_REDIRECT_URL=http://localhost:4173/oauth2/callback
OAUTH2_PROXY_SKIP_PROVIDER_BUTTON=false
OAUTH2_PROXY_OIDC_ISSUER_URL=
