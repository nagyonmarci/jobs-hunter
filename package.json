{
  "name": "job-search-directus-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.browser.json",
    "build:admin": "tsc -p tsconfig.browser.json",
    "typecheck": "tsc --noEmit",
    "provision:directus": "node --import tsx/esm scripts/provision-directus.ts",
    "admin": "python3 -m http.server 4173 --directory public",
    "search:linkedin": "node --import tsx/esm scripts/generate-linkedin-searches.ts",
    "search:linkedin:dry": "node --import tsx/esm scripts/generate-linkedin-searches.ts --dry-run",
    "import:linkedin": "node --import tsx/esm scripts/linkedin-importer.ts",
    "import:linkedin:dry": "node --import tsx/esm scripts/linkedin-importer.ts --dry-run",
    "ingest:jobs": "node --import tsx/esm scripts/ingest-jobs.ts data/jobs.sample.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^4.0.1",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "js-yaml": ">=4.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@google/genai": "^2.10.0",
    "md-to-pdf": "^5.2.5",
    "openai": "^6.45.0",
    "puppeteer": "^25.2.1"
  }
}
